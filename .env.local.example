# ─────────────────────────────────────────────────────────────
# Supabase（Project Settings → API からコピー）
# URL は https://xxxxxxxx.supabase.co のみ（/rest/v1 は付けない）
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# anon public キー（eyJ で始まる長い文字列）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# サーバー専用: 管理者削除/予算管理などで使用（Settings → API → service_role）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# アプリの公開URL（OAuth コールバックのリダイレクトに使用）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 招待コード（合言葉）。サーバー専用 = NEXT_PUBLIC を付けない。
# Googleログイン後、この合言葉を入力した人だけがアプリを使える。
# 友人にはこの値を伝える。好きな文字列に変えてよい。
APP_INVITE_CODE=yakugaku2026

# ─────────────────────────────────────────────────────────────
# Google Gemini（画像からのテキスト抽出・重複判定にのみ使用）
# サーバー専用 = NEXT_PUBLIC を付けない。API Route 内でのみ使用する。
# キーは https://aistudio.google.com/apikey で発行
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# 任意。未設定なら gemini-flash-latest を使用（最新の Flash 名は公式ドキュメントで確認）
GEMINI_MODEL=gemini-3.5-flash
